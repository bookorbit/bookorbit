# Immutable image reference built by CI (use a sha-* tag or @sha256 digest)
APP_IMAGE=ghcr.io/your-org/projectx:sha-<git-sha>

# App publish port on host
APP_PORT=3000

# Database credentials
POSTGRES_USER=projectx
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=projectx

# App secrets
JWT_SECRET=change-this-to-a-long-random-secret
EMAIL_ENCRYPTION_KEY=

# External/public URL used by emails and Kobo endpoints
APP_URL=https://projectx.example.com

# Optional client URL override
CLIENT_URL=https://projectx.example.com

# Optional SMTP config
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@projectx.local

# Optional API keys
GOOGLE_BOOKS_API_KEY=
